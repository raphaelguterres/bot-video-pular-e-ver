{
  "name": "bot-video-pular-e-ver",
  "version": "1.1.0",
  "description": "Aplicativo desktop para detectar o fim de videos em cursos e avancar automaticamente.",
  "author": {
    "name": "Raphael Guterres",
    "email": "raphaelrahh@gmail.com"
  },
  "main": "src/electron/main.js",
  "scripts": {
    "start": "electron .",
    "cli": "node src/bot.js",
    "cli:headed": "HEADLESS=false node src/bot.js",
    "test": "node scripts/run-tests.js",
    "lint": "node scripts/lint.js",
    "format": "node scripts/format-check.js",
    "brave:debug": "powershell -ExecutionPolicy Bypass -File scripts/open-brave-debug.ps1",
    "build": "electron-builder --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:win:portable": "electron-builder --win portable --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "build:mac": "electron-builder --mac --publish never"
  },
  "dependencies": {
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.local.video-course-bot",
    "productName": "Video Course Bot",
    "asar": true,
    "files": [
      "src/**/*",
      "scripts/**/*",
      "config.example.json",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "maintainer": "Raphael Guterres <raphaelrahh@gmail.com>"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    }
  }
}
